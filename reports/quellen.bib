@article{Huber.1996,
	abstract = {Unter einem Ausrei\ss{}er wird ein Datenpaar verstanden, das sich signifikant von den restlichen unterscheidet. Seine Identifizierung erfolgt nach Eliminierung aus dem Datenkollektiv und Neuberechnung der Regressionsdaten entweder {\"u}ber die Pr{\"u}fung der Reststreuungen der beiden Regressionsgeraden mit dem F-Test, oder aber {\"u}ber die Berechnung des Vorhersagebereichs (t-Test) der ausreil{\ss}erfreien Regressionsgeraden. Die beiden Methoden ergeben {\"u}bereinstimmende Resultate. Zur Feststellmag der Nichtlinearit{\"a}t werden die Steigungen der Verbindungsgeraden zwischen den einzelnen Me{\ss}punkten berechnet und einem Trendtest nach Neumann unterworfen. Der Test ist unselektiv und einfach durchf{\"u}hrbar.},
	author = {Huber, Walter},
	year = {1996},
	title = {Nachweis von Ausrei\ss{}ern und Nichtlinearit{\"a}ten bei der Auswertung von Eichreihen {\"u}ber eine Regressionsrechnung},
	pages = {379--383},
	number = {319},
	journal = {Fresenius' Zeitschrift f{\"u}r Analytische Chemie},
